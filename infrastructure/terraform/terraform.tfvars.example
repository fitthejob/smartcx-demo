# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is excluded by .gitignore.

aws_region          = "us-east-1"
project_name        = "smartcx-demo"
alert_email         = "you@example.com"
sentiment_threshold = "-0.5"

# ARN of the Lex v2 bot alias associated with SmartCXOrderBot.
# Must point to a published version — $LATEST is rejected by Connect.
# Build the bot manually in the Lex console first (see docs/setup-guide.md step 2),
# then paste the alias ARN here before running terraform apply.
lex_bot_alias_arn = "arn:aws:lex:us-east-1:ACCOUNT_ID:bot-alias/BOT_ID/ALIAS_ID"

# Initial password for demo-agent and billing-agent Connect users.
# Must meet Connect policy: 8+ chars, upper, lower, number, special character.
# Example: DemoAgent1!
agent_password = "CHANGE_ME"
