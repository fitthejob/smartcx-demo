# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it is excluded by .gitignore.

aws_region          = "us-east-1"
project_name        = "smartcx-demo"
alert_email         = "you@example.com"
sentiment_threshold = "-0.5"

# Initial password for demo-agent and billing-agent Connect users.
# Must meet Connect policy: 8+ chars, upper, lower, number, special character.
# Example: DemoAgent1!
agent_password = "CHANGE_ME"

# Email address for the Cognito dashboard login user.
# This is the account you use to sign in to the SmartCX dashboard.
admin_email = "you@example.com"

# Temporary password for the Cognito dashboard user.
# Must be 12+ chars with uppercase, lowercase, and a number.
# You will be prompted to set a permanent password on first login.
admin_temp_password = "CHANGE_ME_Temp1"
