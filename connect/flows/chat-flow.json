{
  "Version": "2019-10-30",
  "StartAction": "entry",
  "Actions": [
    {
      "Identifier": "entry",
      "Type": "SetLoggingBehavior",
      "Parameters": { "LoggingBehavior": "Enable" },
      "Transitions": { "NextAction": "set-recording", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "set-recording",
      "Type": "SetRecordingAndAnalyticsBehavior",
      "Parameters": {
        "RecordingBehavior": {
          "RecordedParticipants": ["Agent", "Customer"]
        },
        "AnalyticsBehavior": {
          "Enabled": "True",
          "AnalyticsLanguage": "en-US",
          "AnalyticsMode": "PostContact",
          "AnalyticsConfiguration": {
            "ContactLensConfiguration": {
              "RealTimeConfiguration": { "TimestampRange": {} },
              "PostContactConfiguration": { "SummarizationConfiguration": { "PostContactSummarizationEnabled": "False" } }
            }
          }
        }
      },
      "Transitions": { "NextAction": "check-hours", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "check-hours",
      "Type": "CheckHoursOfOperation",
      "Parameters": { "HoursOfOperationId": "$.Queue.HoursOfOperation" },
      "Transitions": {
        "NextAction": "closed-msg",
        "Errors": [],
        "Conditions": [
          { "NextAction": "welcome-msg", "Condition": { "Operator": "Equals", "Operands": ["True"] } }
        ]
      }
    },
    {
      "Identifier": "closed-msg",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "Thank you for contacting ShopFlow support. We are currently closed. Our hours are Monday through Friday, 8 AM to 8 PM Eastern. Please reach out during business hours.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "disconnect", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "disconnect",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    },
    {
      "Identifier": "welcome-msg",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "Welcome to ShopFlow support! You can ask me about your order status or type 'agent' to speak with a support representative.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "get-input", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "get-input",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "How can I help you today?",
        "LexV2Bot": {
          "AliasArn": "$.LexV2BotAliasArn"
        },
        "BotAliasArn": "$.LexV2BotAliasArn",
        "MaxRetries": "2"
      },
      "Transitions": {
        "NextAction": "no-match",
        "Errors": [
          { "NextAction": "no-match", "ErrorType": "NoMatchingError" },
          { "NextAction": "no-match", "ErrorType": "InputTimeLimitExceeded" }
        ],
        "Conditions": [
          { "NextAction": "invoke-order-lookup", "Condition": { "Operator": "Equals", "Operands": ["CheckOrderStatus"] } },
          { "NextAction": "cancel-to-agent", "Condition": { "Operator": "Equals", "Operands": ["CancelOrder"] } }
        ]
      }
    },
    {
      "Identifier": "invoke-order-lookup",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "$.Queue.ARN",
        "InvocationTimeLimitSeconds": "8",
        "LambdaInvocationAttributes": {
          "phone": "$.CustomerEndpoint.Address"
        }
      },
      "Transitions": {
        "NextAction": "order-not-found",
        "Errors": [
          { "NextAction": "lookup-error", "ErrorType": "NoMatchingError" }
        ],
        "Conditions": [
          { "NextAction": "order-found", "Condition": { "Operator": "Equals", "Operands": ["$.Attributes.orderFound", "true"] } }
        ]
      }
    },
    {
      "Identifier": "order-found",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "I found your order! Order $.Attributes.orderId is currently $.Attributes.status. $.Attributes.estimatedDelivery. Is there anything else I can help you with?",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "disconnect", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "order-not-found",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "I'm sorry, I couldn't find an order associated with your contact information. Let me connect you with a support agent.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "set-queue-support", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "lookup-error",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "I'm having trouble looking that up right now. Let me connect you with a support agent.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "set-queue-support", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "cancel-to-agent",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "For cancellations, I'll connect you with an agent right away.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "set-queue-support", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "no-match",
      "Type": "SendMessage",
      "Parameters": {
        "Text": "I'll connect you with a support agent who can help with that.",
        "ContentType": "text/plain"
      },
      "Transitions": { "NextAction": "set-queue-support", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "set-queue-support",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": {
          "queueName": "SupportQueue",
          "sentiment": "unknown"
        }
      },
      "Transitions": { "NextAction": "transfer-support", "Errors": [], "Conditions": [] }
    },
    {
      "Identifier": "transfer-support",
      "Type": "TransferContactToQueue",
      "Parameters": { "QueueId": "$.Queue.ARN" },
      "Transitions": {
        "NextAction": "disconnect",
        "Errors": [{ "NextAction": "disconnect", "ErrorType": "NoMatchingError" }],
        "Conditions": []
      }
    }
  ]
}
